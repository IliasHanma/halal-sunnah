---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { services } from "../../data/services";

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = services.find((s) => s.slug === slug)!;
---

<Layout title={`${service.title} — Halal Sunnah`} description={service.subtitle}>
  <Header />
  <main>

    <!-- Hero -->
    <section class="relative overflow-hidden" style="height: 60vh; min-height: 400px;">
      <img src={service.img} alt={service.title} class="absolute inset-0 w-full h-full object-cover" style="animation: kenBurns 7s var(--ease-expo) forwards;" />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(6,43,82,0.55) 0%, rgba(6,43,82,0.88) 100%);"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4">
        <div class="mb-5" style="opacity:0; animation: fadeUp 1s var(--ease-expo) 0.15s forwards;">
          <span class="eyebrow">Nos services</span>
        </div>
        <h1 class="text-3xl sm:text-5xl font-heading font-bold text-white mb-3 leading-tight" style="opacity:0; animation: fadeUp 1.1s var(--ease-expo) 0.3s forwards;">{service.title}</h1>
        <p class="text-primary-200 text-lg max-w-xl" style="opacity:0; animation: fadeUp 1.1s var(--ease-expo) 0.45s forwards;">{service.subtitle}</p>
      </div>
    </section>

    <!-- Contenu -->
    <section class="bg-white py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Description -->
        <div class="mb-12 reveal">
          <div class="h-1 w-12 bg-accent-gold rounded-full mb-6"></div>
          <p class="text-gray-700 text-lg leading-relaxed">{service.description}</p>
        </div>


        <!-- Journey (Médine uniquement) -->
        {slug === 'visite-de-medine' && (() => {
          const places = [
            { title: "Masjid Nabawi", text: "La Mosquée du Prophète ﷺ, deuxième lieu saint de l'Islam. Chaque prière y vaut 1 000 prières.", img: "/images/medine.jpg" },
            { title: "Mosquée de Quba", text: "La première mosquée bâtie en Islam. Y prier deux rak'ates équivaut à une Omra complète.", img: "/images/islamic-arch.jpg" },
            { title: "Jabal Uhud", text: `Site de la bataille d'Uhud. Le Prophète ﷺ a dit : "Uhud est une montagne qui nous aime."`, img: "/images/medine-uhud.jpg" },
            { title: "Mosquée des Deux Qiblas", text: "Là où la prière fut redirigée de Jérusalem vers La Mecque, un tournant dans l'histoire de l'Islam.", img: "/images/medine2.jpg" },
            { title: "Tranchée (Khandaq)", text: "Site de la bataille du Fossé, où les musulmans creusèrent une tranchée pour défendre Médine.", img: "/images/mosque.jpg" },
            { title: "Jardin de Salman Al-Farisi", text: "Le jardin cultivé par le compagnon Salman Al-Farisi, symbole de patience et de foi.", img: "/images/medine-palmeraie-web.jpg" },
            { title: "Cimetière Al-Baqi'", text: "Lieu de repos de nombreux compagnons du Prophète ﷺ et membres de sa famille.", img: "/images/medine.jpg" },
          ];
          return (
          <div class="mb-12 reveal">
            <div class="h-px w-full bg-gray-100 mb-12"></div>

            <div class="text-center max-w-xl mx-auto mb-16">
              <div class="h-1 w-12 rounded-full mb-5 mx-auto" style="background:#C8A25A;"></div>
              <h2 class="text-2xl sm:text-3xl font-heading font-bold mb-3" style="color:#0F2747;">Le parcours de votre visite</h2>
              <p class="text-gray-400 text-sm">Découvrez les lieux historiques que nous visiterons ensemble à Médine.</p>
            </div>

            <div id="medine-journey">
              <!-- Timeline with circular thumbnails on a curved path -->
              <div class="relative mb-7 overflow-x-auto sm:overflow-visible">
                <div class="relative flex items-start justify-start sm:justify-center min-w-max sm:min-w-0 px-2 sm:px-0 pb-2">

                  <!-- Curved journey path (desktop) -->
                  <svg class="hidden sm:block absolute pointer-events-none" style="left:0; right:0; top:43px; width:100%; height:6px; overflow:visible;" preserveAspectRatio="none" viewBox="0 0 1000 6">
                    <path d="M0,3 Q500,-14 1000,3" fill="none" stroke="#E2E2E2" stroke-width="3" stroke-linecap="round" />
                    <path id="mj-path-gold" d="M0,3 Q500,-14 1000,3" fill="none" stroke="#C8A25A" stroke-width="3" stroke-linecap="round" pathLength="1" stroke-dasharray="1" stroke-dashoffset="1" style="transition: stroke-dashoffset 0.6s cubic-bezier(0.22,1,0.36,1);" />
                  </svg>

                  <div class="relative flex items-start justify-start sm:justify-center gap-1 sm:gap-2 w-full">
                    {places.map((p, i) => (
                      <button type="button" class="mj-thumb relative z-10 flex-shrink-0 flex flex-col items-center gap-3 transition-all duration-300 px-1" data-index={i} aria-label={p.title}>
                        <span class="mj-thumb-halo relative flex items-center justify-center rounded-full transition-all duration-300" style="width:84px; height:84px;">
                          <img src={p.img} alt="" class="mj-thumb-img w-full h-full object-cover rounded-full transition-transform duration-300" style="border:3px solid #FFFFFF; box-shadow:0 3px 10px rgba(15,39,71,0.12);" />
                        </span>
                        <span class="mj-thumb-name text-[10px] sm:text-[11px] font-medium text-center leading-tight whitespace-nowrap transition-colors duration-300" style="color:#9CA3AF;">
                          {p.title}
                        </span>
                      </button>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Slider card -->
              <div class="relative max-w-[720px] mx-auto">
                <button id="mj-prev" type="button" class="mj-arrow hidden sm:flex absolute -left-[76px] top-[38%] -translate-y-1/2 z-10 items-center justify-center bg-white transition-all duration-300" style="width:60px; height:60px; border-radius:9999px; box-shadow:0 10px 28px rgba(15,39,71,0.14);" aria-label="Lieu précédent">
                  <svg class="w-5 h-5 transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="#0F2747" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button id="mj-next" type="button" class="mj-arrow hidden sm:flex absolute -right-[76px] top-[38%] -translate-y-1/2 z-10 items-center justify-center bg-white transition-all duration-300" style="width:60px; height:60px; border-radius:9999px; box-shadow:0 10px 28px rgba(15,39,71,0.14);" aria-label="Lieu suivant">
                  <svg class="w-5 h-5 transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="#0F2747" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>

                <div class="overflow-hidden bg-white" style="border-radius:28px; box-shadow:0 35px 80px rgba(15,30,60,0.10);">
                  <div id="mj-track" class="flex transition-transform duration-[400ms] ease-out">
                    {places.map((p, i) => (
                      <div class="mj-slide w-full flex-shrink-0">
                        <div class="relative overflow-hidden" style="height:280px; border-radius:28px 28px 0 0;">
                          <img
                            src={p.img}
                            alt={p.title}
                            loading={i === 0 ? "eager" : "lazy"}
                            class="mj-img w-full h-full object-cover"
                            style="filter: saturate(0.92) contrast(1.05) brightness(0.98);"
                          />
                        </div>
                        <div class="p-7 sm:p-9">
                          <h3 class="mj-title font-heading font-bold mb-2.5" style="font-size:clamp(1.4rem,2.6vw,1.85rem); color:#0F2747;">
                            {p.title}
                          </h3>
                          <p class="text-gray-400 font-light text-sm sm:text-base leading-relaxed mb-7" style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                            {p.text}
                          </p>
                          <span class="inline-flex items-center gap-2 font-medium text-sm tracking-wide transition-all duration-300" style="color:#C8A25A;">
                            Découvrir l'histoire
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                          </span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
          );
        })()}

        <!-- CTA -->
        <div class="pt-8 border-t border-gray-100 flex flex-col sm:flex-row items-center gap-4 reveal">
          <a
            href={service.waMessage ? `https://wa.me/32497570058?text=${encodeURIComponent(service.waMessage)}` : service.ctaHref}
            target={service.waMessage ? "_blank" : undefined}
            rel={service.waMessage ? "noopener noreferrer" : undefined}
            class="btn-gold font-bold px-10 py-4 rounded-full text-sm tracking-widest uppercase"
          >
            {service.cta}
          </a>
          <a href="/services" class="text-gray-400 hover:text-primary-900 text-sm transition-colors">
            ← Tous nos services
          </a>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* Timeline thumbnails */
  .mj-thumb {
    transform: translateY(0);
  }
  .mj-thumb-img {
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .mj-thumb:hover {
    transform: translateY(-4px);
  }
  .mj-thumb:hover .mj-thumb-halo {
    box-shadow: 0 0 0 5px rgba(200,162,90,0.14);
  }
  .mj-thumb:hover .mj-thumb-img {
    transform: scale(1.06);
    border-color: #FFFFFF !important;
  }
  .mj-thumb:hover .mj-thumb-name {
    color: #0F2747 !important;
  }

  .mj-thumb.is-active .mj-thumb-halo {
    box-shadow: 0 0 0 5px rgba(200,162,90,0.2);
  }
  .mj-thumb.is-active .mj-thumb-img {
    border-color: #C8A25A !important;
    transform: scale(1.05);
  }
  .mj-thumb.is-active .mj-thumb-name {
    color: #C8A25A !important;
    font-weight: 600;
  }

  /* Slide content fade-in on activation */
  .mj-title,
  .mj-slide p,
  .mj-slide span {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .mj-slide.is-active .mj-title { opacity: 1; transform: translateY(0); transition-delay: 0.15s; }
  .mj-slide.is-active p { opacity: 1; transform: translateY(0); transition-delay: 0.25s; }
  .mj-slide.is-active span { opacity: 1; transform: translateY(0); transition-delay: 0.35s; }

  /* Ken Burns on the active image */
  .mj-img {
    transform: scale(1);
  }
  .mj-img.kb-active {
    animation: mjKenBurns 9s ease-out forwards;
  }
  @keyframes mjKenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.04); }
  }

  .mj-arrow:hover {
    box-shadow: 0 12px 28px rgba(200,162,90,0.3) !important;
    transform: translateY(-50%) scale(1.08);
    background: #C8A25A !important;
  }
  .mj-arrow:hover svg {
    stroke: #ffffff !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .mj-img.kb-active { animation: none; }
  }
</style>

<script>
  function initJourney() {
    const track = document.getElementById('mj-track');
    if (!track || track.dataset.init === '1') return;
    track.dataset.init = '1';

    const thumbs = document.querySelectorAll<HTMLButtonElement>('.mj-thumb');
    const pathGold = document.getElementById('mj-path-gold');
    const slides = document.querySelectorAll<HTMLDivElement>('.mj-slide');
    const prevBtn = document.getElementById('mj-prev');
    const nextBtn = document.getElementById('mj-next');
    const total = slides.length;
    let current = 0;

    function goTo(index: number) {
      current = Math.max(0, Math.min(total - 1, index));

      if (track) track.style.transform = `translateX(-${current * 100}%)`;

      thumbs.forEach((t, i) => t.classList.toggle('is-active', i === current));

      if (pathGold) {
        const progress = total > 1 ? current / (total - 1) : 1;
        pathGold.style.strokeDashoffset = String(1 - progress);
      }

      slides.forEach((s, i) => {
        const active = i === current;
        s.classList.toggle('is-active', active);
        const img = s.querySelector('.mj-img');
        if (img) {
          img.classList.remove('kb-active');
          if (active) {
            void (img as HTMLElement).offsetWidth; // restart animation
            img.classList.add('kb-active');
          }
        }
      });
    }

    thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => goTo(i)));
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    goTo(0);
  }

  document.addEventListener('astro:page-load', initJourney);
</script>
