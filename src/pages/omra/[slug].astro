---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const itineraryDefault = [
  { day: "Jour 1", title: "Départ de Bruxelles ou Paris", desc: "Vol direct vers Djeddah. Accueil à l'aéroport et transfert privé vers Médine." },
  { day: "Jours 2-4", title: "Médine Al-Munawwarah", desc: "Visite de Masjid Nabawi, Mosquée de Quba, Jabal Uhud, cimetière Al-Baqi et autres lieux historiques." },
  { day: "Jour 5", title: "Transfert Médine → Makkah", desc: "Transport climatisé vers La Mecque. Installation à l'hôtel à proximité du Haram." },
  { day: "Jours 5-9", title: "Makkah Al-Mukarramah", desc: "Accomplissement de la Omra, prières au Masjid Al-Haram, Tawaf et Sa'i. Temps libre pour l'adoration." },
  { day: "Jour 10", title: "Retour", desc: "Transfert vers l'aéroport de Djeddah. Vol retour vers Bruxelles ou Paris." },
];

export function getStaticPaths() {
  return [
    { params: { slug: "depart-septembre" }, props: { title: "Omra 10 jours", dates: "24 Septembre — 3 Octobre 2026", badge: "PROCHAIN DÉPART", badgeColor: "#C89A3D", hero: "/images/kaaba.jpg" } },
    { params: { slug: "depart-novembre" }, props: { title: "Omra 10 jours", dates: "6 Novembre — 15 Novembre 2026", badge: "BEST-SELLER", badgeColor: "#B8323B", hero: "/images/kaaba-night.jpg" } },
  ];
}

const dep = { ...Astro.props, itinerary: itineraryDefault };

const inclus = [
  { label: "Vols A/R", icon: "plane" },
  { label: "Visa", icon: "id" },
  { label: "Hôtels", icon: "hotel" },
  { label: "Transports", icon: "car" },
  { label: "Petits déj.", icon: "food" },
  { label: "Accompagnement", icon: "guide" },
];

const pricing = [
  { type: "Quadruple", persons: "4 pers./chambre", price: "1 350" },
  { type: "Triple", persons: "3 pers./chambre", price: "1 550" },
  { type: "Double", persons: "2 pers./chambre", price: "1 750" },
];

const hotels = [
  { name: "Bosphorus", location: "Makkah", img: "/images/srv-hotel.jpg" },
  { name: "Voco", location: "Makkah", img: "/images/medine.jpg" },
];

const waText = `As salamo 3alaykoum wa rahmatullahi wa barakaatouh,\n\nJe suis intéressé(e) par votre Omra du ${dep.dates}. Pourriez-vous me contacter pour en discuter ?\n\nMerci bien`;
---

<Layout title={`${dep.title} — ${dep.dates} — Halal Sunnah`} description={`Réservez votre Omra du ${dep.dates}. Forfait tout inclus au départ de Bruxelles ou Paris.`}>
  <Header />
  <main>

    <!-- Hero -->
    <section class="relative overflow-hidden" style="height:55vh; min-height:380px;">
      <img src={dep.hero} alt={dep.title} class="absolute inset-0 w-full h-full object-cover" style="animation: kenBurns 8s cubic-bezier(0.16,1,0.3,1) forwards;" />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(3,20,42,0.3) 0%, rgba(3,20,42,0.85) 100%);"></div>
      <div class="absolute inset-0 flex flex-col items-center justify-end text-center px-4 pb-12">
        <span class="inline-block px-3 py-1.5 rounded-lg text-[10px] font-bold tracking-widest uppercase text-white mb-5" style={`background:${dep.badgeColor};`}>
          {dep.badge}
        </span>
        <h1 class="text-3xl sm:text-5xl font-heading font-bold text-white mb-3 leading-tight">{dep.title}</h1>
        <p class="text-white/70 text-lg">{dep.dates}</p>
        <div class="flex flex-wrap justify-center gap-4 mt-5 text-white/50 text-sm">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Madinah · Makkah
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            10 jours
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
            Départ Bruxelles / Paris
          </span>
        </div>
      </div>
    </section>

    <!-- Prix sticky mobile -->
    <div class="od-sticky-bar sm:hidden fixed bottom-0 left-0 right-0 z-50 bg-white px-4 py-3 flex items-center justify-between" style="box-shadow:0 -4px 20px rgba(0,0,0,0.1); border-top:1px solid #e5e7eb;">
      <div>
        <p class="text-[10px] uppercase tracking-wider text-gray-400">À partir de</p>
        <p class="font-heading font-bold text-xl" style="color:var(--ink);">1 350€ <span class="text-xs font-normal text-gray-400">/pers.</span></p>
      </div>
      <a href={`https://wa.me/32497570058?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-bold text-sm tracking-wider rounded-full px-6 py-3 text-white" style="background:var(--gold);">
        Réserver
      </a>
    </div>

    <section class="bg-white py-16 lg:py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-3 lg:gap-12">

          <!-- Colonne gauche -->
          <div class="lg:col-span-2">

            <!-- Inclus -->
            <div class="mb-14">
              <h2 class="font-heading font-bold text-xl mb-6" style="color:var(--ink);">Forfait tout inclus</h2>
              <div class="grid grid-cols-3 sm:grid-cols-6 gap-4">
                {inclus.map(item => (
                  <div class="flex flex-col items-center gap-2 text-center">
                    <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background:rgba(200,154,61,0.08);">
                      <svg class="w-5 h-5" style="color:var(--gold-deep);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
                      </svg>
                    </div>
                    <span class="text-[11px] font-semibold" style="color:var(--ink);">{item.label}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Itinéraire -->
            <div class="mb-14" id="itineraire">
              <h2 class="font-heading font-bold text-xl mb-8" style="color:var(--ink);">Votre itinéraire</h2>
              <div class="od-timeline relative" style="padding-left:44px;">
                <!-- Ligne de fond grise -->
                <div class="tl-track absolute" style="left:14px; top:15px; bottom:15px; width:2px; background:#e5e7eb;"></div>
                <!-- Ligne dorée qui progresse au scroll -->
                <div class="tl-progress absolute" id="tl-gold" style="left:14px; top:15px; width:2px; height:0;"></div>

                {dep.itinerary.map((step: any, i: number) => (
                  <div class="od-step relative pb-12 last:pb-0" data-step={i}>
                    <div class="tl-dot absolute flex items-center justify-center z-10" style={`left:-44px; top:0; width:30px; height:30px; border-radius:50%; background:var(--navy-950); color:#fff; font-size:12px; font-weight:700; border:3px solid #e5e7eb; transition: background 0.5s ease, border-color 0.5s ease, box-shadow 0.5s ease;`}>
                      {i + 1}
                    </div>
                    <div>
                      <p class="text-[11px] uppercase tracking-wider font-bold mb-1.5" style="color:var(--gold-deep);">{step.day}</p>
                      <h3 class="font-heading font-bold text-lg mb-1" style="color:var(--ink);">{step.title}</h3>
                      <p class="text-gray-500 text-sm leading-relaxed">{step.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Hôtels -->
            <div class="mb-14 lg:mb-0">
              <h2 class="font-heading font-bold text-xl mb-6" style="color:var(--ink);">Nos hôtels</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {hotels.map(hotel => (
                  <div class="group relative overflow-hidden rounded-2xl" style="aspect-ratio:16/10;">
                    <img src={hotel.img} alt={hotel.name} loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(3,20,42,0.8) 0%, transparent 50%);"></div>
                    <div class="absolute bottom-0 left-0 right-0 p-5">
                      <p class="text-white font-heading font-bold text-lg">{hotel.name}</p>
                      <p class="text-white/50 text-xs">{hotel.location}</p>
                    </div>
                  </div>
                ))}
              </div>
              <p class="text-gray-400 text-xs mt-3 italic">Photos à titre indicatif. Les hôtels peuvent varier selon la disponibilité.</p>
            </div>

          </div>

          <!-- Colonne droite - Prix -->
          <div class="lg:col-span-1">
            <div class="od-price-box sticky top-28 bg-white rounded-2xl p-6 lg:p-7" style="border:1px solid #e5e7eb; box-shadow:0 8px 30px -10px rgba(6,43,82,0.1);">
              <div class="text-center mb-6">
                <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-white mb-4" style={`background:${dep.badgeColor};`}>
                  {dep.badge}
                </span>
                <p class="text-[10px] uppercase tracking-wider text-gray-400 mb-1">À partir de</p>
                <p class="font-heading font-bold" style="font-size:2.8rem; color:var(--ink); line-height:1;">
                  1 350€
                </p>
                <p class="text-sm text-gray-400 mt-1">/personne · base quadruple</p>
              </div>

              <div class="h-px bg-gray-100 mb-5"></div>

              <div class="space-y-3 mb-6">
                {pricing.map(p => (
                  <div class="flex items-center justify-between py-2 px-3 rounded-xl" style="background:#f9fafb;">
                    <div>
                      <p class="text-sm font-semibold" style="color:var(--ink);">{p.type}</p>
                      <p class="text-[11px] text-gray-400">{p.persons}</p>
                    </div>
                    <p class="font-heading font-bold text-base" style="color:var(--ink);">{p.price}€</p>
                  </div>
                ))}
              </div>

              <div class="space-y-2 mb-6">
                {["Visa", "Vols A/R", "Transferts", "Hôtels", "Petits déj.", "Accompagnement"].map(item => (
                  <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 flex-shrink-0" style="color:var(--gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {item}
                  </div>
                ))}
              </div>

              <a href={`https://wa.me/32497570058?text=${encodeURIComponent(waText)}`} target="_blank" rel="noopener noreferrer"
                class="od-cta-btn w-full inline-flex items-center justify-center gap-2 font-bold text-sm tracking-wider rounded-xl px-6 py-4 text-white transition-all duration-300"
                style="background:var(--gold);">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.468a.75.75 0 00.942.942l4.434-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.319 0-4.476-.696-6.279-1.891a.75.75 0 00-.607-.1l-3.192 1.076 1.076-3.192a.75.75 0 00-.1-.607A9.952 9.952 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                Réserver cette Omra
              </a>

              <p class="text-center text-[11px] text-gray-400 mt-3">Paiement flexible · 1/3 à la réservation</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA retour -->
    <section class="py-12 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <a href="/" class="text-gray-400 hover:text-gray-600 text-sm transition-colors">← Retour à l'accueil</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  @keyframes kenBurns {
    from { transform: scale(1); }
    to { transform: scale(1.06); }
  }

  .od-price-box {
    transition: box-shadow 0.3s;
  }
  .od-price-box:hover {
    box-shadow: 0 16px 50px -15px rgba(6, 43, 82, 0.18);
  }

  .od-cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px -5px rgba(200, 154, 61, 0.4);
  }

  .tl-progress {
    background: var(--gold);
    transition: height 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tl-dot.active {
    background: var(--gold) !important;
    border-color: var(--gold) !important;
    box-shadow: 0 0 0 5px rgba(200, 154, 61, 0.12);
  }

  .od-step {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .od-step.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .od-sticky-bar {
    padding-bottom: env(safe-area-inset-bottom, 12px);
  }

  @media (min-width: 640px) {
    main { padding-bottom: 0; }
  }
  @media (max-width: 639px) {
    main { padding-bottom: 80px; }
  }
</style>

<script>
  function initTimeline() {
    const timeline = document.querySelector('.od-timeline') as HTMLElement;
    if (!timeline) return;

    const progress = document.getElementById('tl-gold') as HTMLElement;
    const track = timeline.querySelector('.tl-track') as HTMLElement;
    const steps = timeline.querySelectorAll('.od-step');
    const dots = timeline.querySelectorAll('.tl-dot');

    function update() {
      const trigger = window.innerHeight * 0.78;

      let lastActiveIndex = -1;

      steps.forEach((step, i) => {
        const rect = step.getBoundingClientRect();
        if (rect.top < trigger) {
          step.classList.add('visible');
          dots[i]?.classList.add('active');
          lastActiveIndex = i;
        } else {
          step.classList.remove('visible');
          dots[i]?.classList.remove('active');
        }
      });

      if (lastActiveIndex < 0) {
        progress.style.height = '0px';
        return;
      }

      const timelineTop = timeline.getBoundingClientRect().top;
      const firstDotCenter = (dots[0] as HTMLElement).getBoundingClientRect().top + 15 - timelineTop;
      const lastDotCenter = (dots[lastActiveIndex] as HTMLElement).getBoundingClientRect().top + 15 - timelineTop;

      progress.style.top = firstDotCenter + 'px';
      progress.style.height = Math.max(0, lastDotCenter - firstDotCenter) + 'px';
    }

    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    setTimeout(update, 200);
  }

  document.addEventListener('astro:page-load', initTimeline);
  initTimeline();
</script>
