---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Réservation Omra Badal — Halal Sunnah" description="Réservez une Omra Badal (par procuration) pour un proche. Formulaire simple et rapide.">
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-16">
      <div class="absolute inset-0">
        <img src="/images/kaaba2.jpg" alt="" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-b from-primary-900/85 to-primary-800/90"></div>
      </div>
      <div class="relative z-10 max-w-3xl mx-auto px-4 text-center">
        <div class="mb-6" style="opacity:0; animation: fadeUp 1s var(--ease-expo) 0.1s forwards;">
          <span class="eyebrow">Omra par procuration</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-heading font-bold text-white mb-4" style="opacity:0; animation: fadeUp 1.1s var(--ease-expo) 0.25s forwards;">Réservation Omra Badal</h1>
        <p class="text-primary-100 text-lg max-w-xl mx-auto leading-relaxed" style="opacity:0; animation: fadeUp 1.1s var(--ease-expo) 0.4s forwards;">
          Accomplissez une Omra au nom d'un proche décédé ou dans l'incapacité de voyager. Remplissez le formulaire ci-dessous, nous vous recontacterons rapidement.
        </p>
      </div>
    </section>

    <!-- Form section -->
    <section class="py-16 lg:py-24 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="bg-white rounded-3xl shadow-lg border border-gray-100 overflow-hidden">
          <!-- Decorative top bar -->
          <div class="h-2 bg-gradient-to-r from-primary-700 via-primary-500 to-accent-gold"></div>

          <div class="p-8 sm:p-12">
            <!-- Form -->
            <form id="badal-form" class="space-y-8" novalidate>
              <!-- Client info -->
              <div>
                <h2 class="text-xl font-heading font-bold text-primary-900 mb-1">Vos informations</h2>
                <p class="text-gray-500 text-sm mb-6">Ces informations nous permettent de vous recontacter.</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div>
                    <label for="prenom" class="block text-sm font-semibold text-gray-700 mb-1.5">Prénom <span class="text-red-500">*</span></label>
                    <input type="text" id="prenom" name="prenom" required placeholder="Votre prénom"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 placeholder:text-gray-400" />
                  </div>
                  <div>
                    <label for="nom" class="block text-sm font-semibold text-gray-700 mb-1.5">Nom <span class="text-red-500">*</span></label>
                    <input type="text" id="nom" name="nom" required placeholder="Votre nom"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 placeholder:text-gray-400" />
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mt-5">
                  <div>
                    <label for="whatsapp" class="block text-sm font-semibold text-gray-700 mb-1.5">
                      Numéro WhatsApp <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                      <div class="absolute left-3 top-1/2 -translate-y-1/2 text-green-600">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                      </div>
                      <input type="tel" id="whatsapp" name="whatsapp" required placeholder="+32 497 57 00 58"
                        class="w-full pl-10 pr-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 placeholder:text-gray-400" />
                    </div>
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
                    <input type="email" id="email" name="email" placeholder="votre@email.com"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 placeholder:text-gray-400" />
                  </div>
                </div>
              </div>

              <!-- Divider -->
              <div class="flex items-center gap-4">
                <div class="flex-1 h-px bg-gray-200"></div>
                <div class="w-8 h-8 rounded-full bg-primary-50 flex items-center justify-center">
                  <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                </div>
                <div class="flex-1 h-px bg-gray-200"></div>
              </div>

              <!-- Défunt info -->
              <div>
                <h2 class="text-xl font-heading font-bold text-primary-900 mb-1">Informations du bénéficiaire</h2>
                <p class="text-gray-500 text-sm mb-6">La personne au nom de laquelle la Omra sera accomplie.</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div>
                    <label for="defunt-prenom" class="block text-sm font-semibold text-gray-700 mb-1.5">Prénom du bénéficiaire <span class="text-red-500">*</span></label>
                    <input type="text" id="defunt-prenom" name="defunt-prenom" required placeholder="Prénom"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 placeholder:text-gray-400" />
                  </div>
                  <div>
                    <label for="defunt-nom" class="block text-sm font-semibold text-gray-700 mb-1.5">Nom du bénéficiaire <span class="text-red-500">*</span></label>
                    <input type="text" id="defunt-nom" name="defunt-nom" required placeholder="Nom"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 placeholder:text-gray-400" />
                  </div>
                </div>
              </div>

              <!-- Divider -->
              <div class="flex items-center gap-4">
                <div class="flex-1 h-px bg-gray-200"></div>
                <div class="w-8 h-8 rounded-full bg-primary-50 flex items-center justify-center">
                  <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                </div>
                <div class="flex-1 h-px bg-gray-200"></div>
              </div>

              <!-- Dates -->
              <div>
                <h2 class="text-xl font-heading font-bold text-primary-900 mb-1">Période souhaitée</h2>
                <p class="text-gray-500 text-sm mb-4">Durée minimum : 2 jours — Durée maximum : 10 jours.</p>

                <!-- Bouton Choisir ma période -->
                <button type="button" id="toggle-dates"
                  class="inline-flex items-center gap-3 bg-primary-50 hover:bg-primary-100 text-primary-700 font-semibold px-6 py-3 rounded-xl border-2 border-dashed border-primary-300 hover:border-primary-400 transition-all w-full justify-center">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                  Choisir ma période
                  <svg id="toggle-arrow" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </button>

                <!-- Calendrier (caché par défaut) -->
                <div id="date-picker-panel" class="hidden mt-5 bg-primary-50/50 rounded-2xl p-6 border border-primary-100">
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                      <label for="date-debut" class="block text-sm font-semibold text-gray-700 mb-1.5">Date de début <span class="text-red-500">*</span></label>
                      <input type="text" id="date-debut" name="date-debut" required placeholder="JJ/MM/AAAA" readonly
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 bg-white cursor-pointer" />
                    </div>
                    <div>
                      <label for="date-fin" class="block text-sm font-semibold text-gray-700 mb-1.5">Date de fin <span class="text-red-500">*</span></label>
                      <input type="text" id="date-fin" name="date-fin" required placeholder="JJ/MM/AAAA" readonly
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 outline-none transition-all text-gray-800 bg-white cursor-pointer" />
                    </div>
                  </div>
                  <div id="date-info" class="mt-3 text-sm hidden"></div>
                  <div id="date-error" class="mt-3 text-sm text-red-600 hidden"></div>
                </div>

                <!-- Message de confiance -->
                <div class="mt-5 bg-amber-50 border border-amber-200 rounded-xl p-5 flex gap-4">
                  <div class="flex-shrink-0 mt-0.5">
                    <svg class="w-6 h-6 text-accent-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                  </div>
                  <p class="text-sm text-gray-700 leading-relaxed">
                    La Omra Badal sera réalisée dans la période que vous avez choisie, selon disponibilité. La date exacte sera confirmée avec vous avant l'exécution. Nous vous contacterons rapidement sur <strong>WhatsApp</strong> pour finaliser la réservation.
                  </p>
                </div>
              </div>

              <!-- Submit -->
              <button type="submit" id="submit-btn"
                class="btn-gold w-full font-bold py-4 px-8 rounded-xl text-sm tracking-[0.14em] uppercase flex items-center justify-center gap-3">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Réserver maintenant
              </button>
            </form>

          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
<script src="https://cdn.jsdelivr.net/npm/flatpickr" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js" is:inline></script>

<script>
  function initBadal() {
  const form = document.getElementById("badal-form") as HTMLFormElement;
  if (!form || form.dataset.init === "1") return;
  // flatpickr est chargé via CDN : on attend qu'il soit disponible
  if (!(window as any).flatpickr) {
    setTimeout(initBadal, 120);
    return;
  }
  form.dataset.init = "1";

  const dateDebutEl = document.getElementById("date-debut") as HTMLInputElement;
  const dateFinEl = document.getElementById("date-fin") as HTMLInputElement;
  const dateError = document.getElementById("date-error") as HTMLElement;
  const dateInfo = document.getElementById("date-info") as HTMLElement;

  const toggleBtn = document.getElementById("toggle-dates") as HTMLButtonElement;
  const datePanel = document.getElementById("date-picker-panel") as HTMLElement;
  const toggleArrow = document.getElementById("toggle-arrow") as HTMLElement;

  toggleBtn.addEventListener("click", () => {
    const isHidden = datePanel.classList.toggle("hidden");
    toggleArrow.style.transform = isHidden ? "" : "rotate(180deg)";
    if (!isHidden) datePanel.scrollIntoView({ behavior: "smooth", block: "nearest" });
  });

  let startDate: Date | null = null;
  let endDate: Date | null = null;

  function validateDates(): boolean {
    dateError.classList.add("hidden");
    dateInfo.classList.add("hidden");
    if (!startDate || !endDate) return true;
    const diffDays = Math.round((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24));
    if (endDate <= startDate) {
      dateError.textContent = "La date de fin doit être après la date de début.";
      dateError.classList.remove("hidden");
      return false;
    }
    if (diffDays < 2) {
      dateError.textContent = "La durée minimum est de 2 jours.";
      dateError.classList.remove("hidden");
      return false;
    }
    if (diffDays > 10) {
      dateError.textContent = "La durée maximum est de 10 jours.";
      dateError.classList.remove("hidden");
      return false;
    }
    dateInfo.textContent = `Durée sélectionnée : ${diffDays} jour${diffDays > 1 ? "s" : ""}`;
    dateInfo.classList.remove("hidden");
    dateInfo.classList.add("text-primary-600");
    return true;
  }

  const fpDebut = (window as any).flatpickr(dateDebutEl, {
    locale: "fr",
    dateFormat: "d/m/Y",
    minDate: "today",
    disableMobile: true,
    onChange: (selectedDates: Date[]) => {
      startDate = selectedDates[0] || null;
      if (startDate) {
        const min2 = new Date(startDate); min2.setDate(min2.getDate() + 2);
        const max10 = new Date(startDate); max10.setDate(max10.getDate() + 10);
        fpFin.set("minDate", min2);
        fpFin.set("maxDate", max10);
      }
      validateDates();
    },
  });

  const fpFin = (window as any).flatpickr(dateFinEl, {
    locale: "fr",
    dateFormat: "d/m/Y",
    minDate: "today",
    disableMobile: true,
    onChange: (selectedDates: Date[]) => {
      endDate = selectedDates[0] || null;
      validateDates();
    },
  });

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    if (!validateDates()) return;

    const prenom = (document.getElementById("prenom") as HTMLInputElement).value.trim();
    const nom = (document.getElementById("nom") as HTMLInputElement).value.trim();
    const whatsapp = (document.getElementById("whatsapp") as HTMLInputElement).value.trim();
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const defuntPrenom = (document.getElementById("defunt-prenom") as HTMLInputElement).value.trim();
    const defuntNom = (document.getElementById("defunt-nom") as HTMLInputElement).value.trim();

    if (!prenom || !nom || !whatsapp || !defuntPrenom || !defuntNom || !dateDebutEl.value || !dateFinEl.value) {
      alert("Veuillez remplir tous les champs obligatoires.");
      return;
    }

    const message = encodeURIComponent(
      `As salamo 3alaykoum wa rahmatullahi wa barakaatouh,\n\n` +
      `Nous voudrions que la Omra Badal soit réalisée au nom de ${defuntPrenom} ${defuntNom}.\n\n` +
      `*Période souhaitée :* du ${dateDebutEl.value} au ${dateFinEl.value}\n\n` +
      `Vos informations :\n\n` +
      `*Nom :* ${nom}\n` +
      `*Prénom :* ${prenom}\n\n` +
      `Qu'Allah accepte de vous cette noble oeuvre !`
    );

    window.open(`https://wa.me/32497570058?text=${message}`, "_blank");
  });
  }

  document.addEventListener("astro:page-load", initBadal);
</script>
