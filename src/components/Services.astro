---
import { services } from "../data/services";
---

<section id="services" class="py-24 lg:py-32" style="background: var(--mist);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="eyebrow mb-5">Nos services</span>
      <h2 class="font-heading font-bold mb-4" style="font-size: clamp(1.9rem, 3.4vw, 2.7rem); color: var(--ink);">
        Nos services et accompagnements
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        Un accompagnement complet, du visa au retour, pour que votre Omra
        soit une expérience spirituelle inoubliable.
      </p>
    </div>

    <div id="svc-stack" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5 mb-14" data-stagger="80">
      {services.map((service, i) => (
        <a href={`/services/${service.slug}`} class="svc-tile reveal group relative overflow-hidden rounded-2xl" style={`--i:${i};`}>
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={service.img}
              alt={service.title}
              loading="lazy"
              class="svc-tile-img w-full h-full object-cover"
            />
          </div>
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(6,43,82,0.88), rgba(6,43,82,0.18) 55%, transparent);"></div>
          <div class="svc-tile-line absolute top-0 left-0 right-0 h-0.5" style="background: linear-gradient(to right, var(--gold-light), var(--gold));"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-5">
            <h3 class="svc-tile-title text-white font-bold text-sm uppercase tracking-wide leading-tight">{service.title}</h3>
            <p class="svc-tile-sub text-xs mt-1.5" style="color: #b8cce4;">{service.subtitle}</p>
            <span class="svc-tile-cta inline-flex items-center gap-1.5 text-xs font-semibold mt-2" style="color: var(--gold-light);">
              Découvrir
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center reveal">
      <a href="/services" class="btn-gold inline-flex items-center gap-2 font-bold px-10 py-4 rounded-full text-sm tracking-[0.08em] uppercase">
        Découvrir tous nos services
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .svc-tile {
    box-shadow: 0 6px 20px -8px rgba(6, 43, 82, 0.15);
    /* opacity/filter inclus pour ne pas casser l'animation .reveal */
    transition:
      transform 0.6s var(--ease-expo),
      box-shadow 0.6s var(--ease-expo),
      opacity 1s var(--ease-expo),
      filter 1s var(--ease-expo);
  }
  .svc-tile.reveal:not(.visible) {
    transition:
      opacity 1s var(--ease-expo),
      transform 1s var(--ease-expo),
      filter 1s var(--ease-expo);
  }
  .svc-tile:hover {
    transform: translateY(-6px) scale(1.015);
    box-shadow: 0 28px 55px -18px rgba(6, 43, 82, 0.35);
  }

  .svc-tile-img {
    transition: transform 1s var(--ease-expo), filter 0.6s;
    filter: saturate(0.95);
  }
  .svc-tile:hover .svc-tile-img {
    transform: scale(1.08);
    filter: saturate(1.05);
  }

  .svc-tile-line {
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.55s var(--ease-expo);
  }
  .svc-tile:hover .svc-tile-line {
    transform: scaleX(1);
  }

  /* Alignement uniforme : chaque titre occupe la place de 2 lignes,
     texte calé en HAUT — tous les titres démarrent à la même hauteur,
     et les sous-titres aussi (zone de 2 lignes réservée) */
  .svc-tile-title {
    min-height: 2.5em;
  }
  .svc-tile-sub {
    min-height: 2.7em;
  }

  .svc-tile-sub,
  .svc-tile-cta {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.5s var(--ease-expo),
      transform 0.5s var(--ease-expo);
  }
  .svc-tile-cta {
    transition-delay: 0.06s;
  }
  .svc-tile:hover .svc-tile-sub,
  .svc-tile:hover .svc-tile-cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* Sur mobile (pas de hover), on montre le sous-titre */
  @media (hover: none) {
    .svc-tile-sub {
      opacity: 1;
      transform: none;
    }
  }
</style>
