---
---

<section id="hero" class="relative w-full min-h-screen" style="background: var(--navy-900);">
  <!-- Photo de fond -->
  <div class="absolute inset-0 z-0 overflow-hidden">
    <img
      id="hero-bg"
      src="/images/hero-kaaba.jpg"
      alt="La Kaaba - La Mecque"
      class="w-full h-full object-cover"
      style="object-position: center 62%; filter: brightness(1.08) contrast(1.06) saturate(1.08);"
    />
    <!-- Dégradé bleu nuit : gauche sombre -> droite transparente -->
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(6,43,82,0.97) 0%, rgba(6,43,82,0.93) 30%, rgba(6,43,82,0.62) 45%, rgba(6,43,82,0.08) 62%, rgba(6,43,82,0) 75%);"></div>
    <!-- Vignette guidant le regard vers la Kaaba -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 55% 65% at 72% 58%, transparent 40%, rgba(0,0,0,0.22) 100%); box-shadow: inset 0 0 160px rgba(0,0,0,0.3);"></div>
    <!-- Voile bas pour fondre vers la section suivante -->
    <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to top, rgba(3,20,42,0.75), transparent);"></div>
  </div>

  <!-- Contenu -->
  <div class="relative z-10 min-h-screen flex flex-col justify-center">
    <div class="w-full px-6 sm:px-10 lg:px-20 py-16">
      <div class="max-w-[620px]">

        <!-- Slogan -->
        <p class="hero-fade text-xs sm:text-sm font-semibold tracking-[0.14em] mb-6" style="color: var(--gold-light); animation-delay: 0.1s;">
          Vous préparez votre intention. Halal Sunnah s'occupe du reste.
        </p>

        <!-- Titre : révélation par lignes masquées -->
        <h1 class="font-heading font-bold mb-7 leading-[1.08]" style="font-size: clamp(2.6rem, 5.6vw, 4.6rem); text-shadow: 0 6px 40px rgba(0,0,0,0.35);">
          <span class="line-mask"><span class="line-inner text-white" style="animation-delay: 0.25s;">Votre Omra,</span></span>
          <span class="line-mask"><span class="line-inner gold-shimmer" style="animation-delay: 0.42s;">notre engagement.</span></span>
        </h1>

        <!-- Filet doré animé -->
        <div class="hero-fade flex items-center gap-2 mb-7" style="animation-delay: 0.6s;">
          <div class="gold-line-grow h-px w-40"></div>
          <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--gold);"></span>
        </div>

        <!-- Texte descriptif -->
        <p class="hero-fade text-white/85 font-light leading-relaxed mb-11 max-w-[520px]" style="font-size: clamp(0.95rem, 1.15vw, 1.05rem); animation-delay: 0.72s;">
          Avec Halal Sunnah, nous prenons en charge chaque étape de votre voyage afin que vous puissiez vous consacrer pleinement à votre adoration.
        </p>

        <!-- Boutons -->
        <div class="hero-fade flex flex-col sm:flex-row gap-4 w-full sm:w-auto" style="animation-delay: 0.9s;">
          <a
            href="/services"
            class="btn-gold inline-flex items-center justify-center gap-2 px-9 py-4 font-bold text-sm tracking-[0.08em] rounded-full w-full sm:w-auto"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18" /></svg>
            Réserver ma Omra
          </a>
          <a
            href="#services"
            class="btn-ghost inline-flex items-center justify-center gap-2 px-9 py-4 font-semibold text-sm tracking-[0.08em] rounded-full w-full sm:w-auto group"
          >
            Découvrir nos forfaits
            <span class="inline-block transition-transform duration-500 group-hover:translate-x-1.5">→</span>
          </a>
        </div>

      </div>
    </div>
  </div>

  <!-- Logo médaillon -->
  <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 z-40">
    <div class="medallion w-20 h-20 rounded-full flex items-center justify-center">
      <img src="/images/logo.png" alt="Halal Sunnah" class="w-14 h-14 object-contain" />
    </div>
  </div>
</section>

<style>
  /* Ken Burns lent sur la photo, combiné au parallaxe JS via la variable --par */
  #hero-bg {
    --par-x: 0px;
    --par-y: 0px;
    transform: translate3d(var(--par-x), var(--par-y), 0) scale(var(--kb, 1.08));
    animation: heroKenBurns 8s var(--ease-expo) forwards;
    will-change: transform;
  }
  @keyframes heroKenBurns {
    from { --kb: 1.08; }
    to { --kb: 1; }
  }
  @property --kb {
    syntax: "<number>";
    inherits: false;
    initial-value: 1.08;
  }

  .hero-fade {
    opacity: 0;
    animation: fadeUp 1.1s var(--ease-expo) forwards;
  }

  /* Révélation du titre par lignes masquées */
  /* Révélation par ligne : montée + fondu + défloutage — aucun masque, rien n'est coupé */
  .line-mask {
    display: block;
  }
  .line-inner {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.4em);
    animation: lineUp 1.2s var(--ease-expo) forwards;
  }
  @keyframes lineUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Or scintillant sur la seconde ligne.
     background-clip:text ne peint le dégradé que dans la boîte de l'élément :
     on l'agrandit (padding + marges négatives) pour couvrir jambages et accents,
     sinon le bas des lettres reste transparent (donc invisible). */
  .gold-shimmer {
    padding: 0.15em 0.1em 0.35em;
    margin: -0.15em -0.1em -0.35em;
    background: linear-gradient(
      100deg,
      var(--gold) 0%,
      var(--gold) 40%,
      var(--gold-light) 50%,
      var(--gold) 60%,
      var(--gold) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: lineUp 1.1s var(--ease-expo) forwards, shimmerText 6s linear 2s infinite;
  }

  .gold-line-grow {
    background: linear-gradient(to right, var(--gold), rgba(201, 162, 75, 0.3));
    transform-origin: left;
    animation: lineGrow 1.2s var(--ease-expo) 0.7s backwards;
  }
  @keyframes lineGrow {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .medallion {
    background: var(--navy-950);
    border: 3px solid var(--gold);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35), 0 0 0 0 rgba(201, 162, 75, 0.4);
    animation: medallionPulse 4s ease-in-out 2s infinite;
  }
  @keyframes medallionPulse {
    0%, 100% { box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35), 0 0 0 0 rgba(201, 162, 75, 0.35); }
    50% { box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35), 0 0 0 12px rgba(201, 162, 75, 0); }
  }

  @media (max-width: 1023px) {
    #hero-bg {
      object-position: 68% center;
    }
  }
</style>

<script>
  function initHero() {
    const heroSection = document.getElementById("hero");
    const heroBg = document.getElementById("hero-bg") as HTMLImageElement | null;
    if (!heroSection || !heroBg || heroSection.dataset.init === "1") return;
    heroSection.dataset.init = "1";

    let scrollY = 0;
    let mouseX = 0;
    let mouseY = 0;
    let ticking = false;

    function applyParallax() {
      if (!heroBg) return;
      heroBg.style.setProperty("--par-x", `${mouseX * 10}px`);
      heroBg.style.setProperty("--par-y", `${scrollY * 0.15 + mouseY * 6}px`);
      ticking = false;
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!document.body.contains(heroBg)) return;
        if (window.scrollY < window.innerHeight) {
          scrollY = window.scrollY;
          if (!ticking) {
            requestAnimationFrame(applyParallax);
            ticking = true;
          }
        }
      },
      { passive: true }
    );

    heroSection.addEventListener("mousemove", (e) => {
      const rect = heroSection.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width - 0.5;
      mouseY = (e.clientY - rect.top) / rect.height - 0.5;
      if (!ticking) {
        requestAnimationFrame(applyParallax);
        ticking = true;
      }
    });
  }

  document.addEventListener("astro:page-load", initHero);
</script>
