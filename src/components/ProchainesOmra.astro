---
const inclusions = [
  { label: "Vols", icon: "plane" },
  { label: "Visa", icon: "visa" },
  { label: "Hôtels", icon: "bed" },
  { label: "Transports", icon: "car" },
  { label: "Petits déjeuners", icon: "coffee" },
];

const formules = [
  { key: "double", label: "Chambre double", prix: "1 750 €" },
  { key: "triple", label: "Chambre triple", prix: "1 550 €", star: true },
  { key: "quadruple", label: "Chambre quadruple", prix: "1 350 €" },
];
---

<section id="prochaines-omra" class="relative py-24 lg:py-32" style="background: var(--navy-950);">
  <!-- Halo doré discret -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 45% at 50% 0%, rgba(201,162,75,0.08), transparent 70%);"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- En-tête -->
    <div class="text-center max-w-2xl mx-auto mb-12 reveal">
      <span class="eyebrow mb-5">Prochains départs · 2026 — 1448</span>
      <h2 class="font-heading font-bold mb-4 text-white" style="font-size: clamp(1.9rem, 3.4vw, 2.7rem);">
        Nos prochaines <span style="color: var(--gold-light);">Omra</span>
      </h2>
      <p class="text-lg" style="color: #b8cce4;">
        Départ de Bruxelles ou de Paris — forfait tout inclus.
      </p>
      <div class="gold-hr w-32 mx-auto mt-7"></div>
    </div>

    <!-- Inclusions -->
    <div class="flex flex-wrap justify-center gap-2.5 mb-12 reveal">
      {inclusions.map((inc) => (
        <span class="po-pill inline-flex items-center gap-2 text-xs font-medium tracking-wide px-4 py-2 rounded-full">
          {inc.icon === "plane" && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>}
          {inc.icon === "visa" && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M7 9h4M7 12h2M15.5 11a1.5 1.5 0 100 3 1.5 1.5 0 000-3z"/></svg>}
          {inc.icon === "bed" && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v11M3 14h18v4M3 11h18v0M7 11V9a1 1 0 011-1h3v3"/></svg>}
          {inc.icon === "car" && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 17H3v-5l2-5h12l3 5v5h-2M7 17a2 2 0 104 0M13 17a2 2 0 104 0M7 17h6"/></svg>}
          {inc.icon === "coffee" && <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 10h12v6a4 4 0 01-4 4H8a4 4 0 01-4-4v-6zM16 11h1.5a2.5 2.5 0 010 5H16M7 7V5M10 7V4M13 7V5"/></svg>}
          {inc.label}
        </span>
      ))}
    </div>

    <!-- Dates de départ -->
    <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto mb-12 reveal" data-stagger="90">
      <div class="po-date rounded-2xl px-6 py-5">
        <div class="flex items-center gap-2 text-[0.65rem] font-semibold tracking-[0.2em] mb-2" style="color: var(--gold);">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/></svg>
          DÉPART 1
        </div>
        <p class="text-white font-semibold" style="font-size: 1.05rem;">24 septembre → 3 octobre</p>
        <p class="text-xs mt-1.5" style="color: #b8cce4;">10 jours · Médine &amp; La Mecque</p>
      </div>
      <div class="po-date rounded-2xl px-6 py-5">
        <div class="flex items-center gap-2 text-[0.65rem] font-semibold tracking-[0.2em] mb-2" style="color: var(--gold);">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/></svg>
          DÉPART 2
        </div>
        <p class="text-white font-semibold" style="font-size: 1.05rem;">6 novembre → 15 novembre</p>
        <p class="text-xs mt-1.5" style="color: #b8cce4;">10 jours · Médine &amp; La Mecque</p>
      </div>
    </div>

    <!-- Formules / tarifs : cliquables vers la page détail -->
    <div class="grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto mb-12 reveal" data-stagger="90">
      {formules.map((f) => (
        <a href={`/omra-2026?formule=${f.key}`} class={`po-card group relative rounded-2xl px-5 py-7 text-center block ${f.star ? "po-card-star" : ""}`}>
          {f.star && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 text-[0.6rem] font-bold tracking-[0.16em] px-3.5 py-1 rounded-full" style="background: linear-gradient(135deg, var(--gold-light), var(--gold)); color: var(--navy-950);">
              POPULAIRE
            </span>
          )}
          <p class="text-[0.65rem] font-semibold tracking-[0.2em] mb-3" style={f.star ? "color: var(--gold-light);" : "color: #b8cce4;"}>{f.label.toUpperCase()}</p>
          <p class="font-heading font-bold mb-1" style={`font-size: 2rem; color: ${f.star ? "var(--gold-light)" : "#ffffff"};`}>{f.prix}</p>
          <p class="text-[0.7rem] mb-5" style="color: #8fa8c8;">par personne</p>
          <span class="po-cta inline-flex items-center gap-1.5 text-xs font-semibold tracking-wide" style="color: var(--gold);">
            Voir les détails
            <svg class="w-3.5 h-3.5 transition-transform duration-500 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center reveal">
      <a
        href={`https://wa.me/32497570058?text=${encodeURIComponent("As salamo 3alaykoum, je souhaite réserver ma place pour la Omra 2026 (départ de Bruxelles ou Paris).")}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold inline-flex items-center gap-2.5 font-bold px-10 py-4 rounded-full text-sm tracking-[0.08em] uppercase"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Réserver via WhatsApp
      </a>
      <p class="text-xs mt-4" style="color: #8fa8c8;">Places limitées — réponse rapide sur WhatsApp</p>
    </div>

  </div>
</section>

<style>
  .po-pill {
    color: var(--gold-light);
    border: 1px solid rgba(201, 162, 75, 0.4);
    background: rgba(201, 162, 75, 0.05);
  }

  .po-date {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(201, 162, 75, 0.35);
  }

  .po-card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition:
      transform 0.5s var(--ease-expo),
      border-color 0.5s var(--ease-smooth),
      background-color 0.5s var(--ease-smooth),
      box-shadow 0.5s var(--ease-expo),
      opacity 1s var(--ease-expo);
  }
  .po-card:hover {
    transform: translateY(-6px);
    border-color: rgba(201, 162, 75, 0.6);
    background: rgba(201, 162, 75, 0.07);
    box-shadow: 0 24px 50px -20px rgba(0, 0, 0, 0.6);
  }
  .po-card-star {
    background: rgba(201, 162, 75, 0.1);
    border-color: var(--gold);
  }
</style>
