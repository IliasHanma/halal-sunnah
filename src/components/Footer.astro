---

<footer class="text-white pt-16 pb-28 sm:pb-10" style="background: var(--navy-950);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Marque -->
      <div>
        <img src="/images/logo.png" alt="Halal Sunnah" class="h-24 w-auto mb-5" />
        <p class="text-white/55 text-sm leading-relaxed max-w-xs">
          Votre partenaire de confiance pour une Omra sereine vers les Lieux Saints.
        </p>
      </div>

      <!-- Liens -->
      <div>
        <h4 class="footer-title">Navigation</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/" class="footer-link">Accueil</a></li>
          <li><a href="/services" class="footer-link">Nos services</a></li>
          <li><a href="/a-propos" class="footer-link">À propos</a></li>
          <li><a href="/reservation-badal" class="footer-link">Réservation Badal</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="footer-title">Contact</h4>
        <ul class="space-y-2.5 text-sm text-white/55">
          <li><a href="mailto:contact@halalsunnah.be" class="footer-link">contact@halalsunnah.be</a></li>
          <li>Médine, Arabie Saoudite</li>
        </ul>
      </div>
    </div>

    <div class="gold-hr mb-10" style="opacity: 0.25;"></div>

    <!-- Réseaux sociaux : centrés, en évidence -->
    <div class="flex flex-col items-center gap-8">
      <p class="text-[0.65rem] font-semibold uppercase tracking-[0.28em]" style="color: var(--gold);">
        Suivez-nous
      </p>
