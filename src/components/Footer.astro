      <!-- Copyright : seul, tout en bas -->
      <p class="text-xs tracking-wider text-center pt-2" style="color: rgba(255,255,255,0.35);">
        &copy; 2026 Halal Sunnah — Tous droits réservés
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-title {
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 1.25rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.55);
    display: inline-block;
    transition:
      color 0.35s var(--ease-smooth),
      transform 0.35s var(--ease-expo);
  }
  .footer-link:hover {
    color: var(--gold-light);
    transform: translateX(4px);
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    color: var(--gold);
    border: 1px solid rgba(201, 162, 75, 0.45);
    background: rgba(201, 162, 75, 0.04);
    transition:
      color 0.4s var(--ease-smooth),
      background-color 0.4s var(--ease-smooth),
      border-color 0.4s var(--ease-smooth),
      transform 0.4s var(--ease-expo),
      box-shadow 0.4s var(--ease-expo);
  }
  .social-icon:hover {
    color: var(--navy-950);
    background: var(--gold);
    border-color: var(--gold);
    transform: translateY(-4px);
    box-shadow: 0 14px 30px -10px rgba(201, 162, 75, 0.55);
  }
</style>
