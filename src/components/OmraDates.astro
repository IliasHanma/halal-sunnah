---
const packages = [
  {
    badge: "PROCHAIN DÉPART",
    badgeColor: "#C89A3D",
    title: "Omra 10 jours",
    subtitle: "24 Sept. — 3 Oct.",
    route: "Madinah · Makkah",
    img: "/images/kaaba.jpg",
    price: "1 350",
    slug: "depart-septembre",
  },
  {
    badge: "BEST-SELLER",
    badgeColor: "#B8323B",
    title: "Omra 10 jours",
    subtitle: "6 — 15 Nov.",
    route: "Madinah · Makkah",
    img: "/images/kaaba-night.jpg",
    price: "1 350",
    slug: "depart-novembre",
  },
];
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex items-end justify-between mb-10">
      <div class="reveal">
        <span class="eyebrow mb-4">Omra 2026 · 1448</span>
        <h2 class="font-heading font-bold" style="font-size: clamp(1.7rem, 3vw, 2.4rem); color: var(--ink);">
          Nos prochains départs
        </h2>
        <p class="text-gray-400 mt-2 text-sm">Forfait tout inclus · Départ Bruxelles ou Paris</p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 reveal">
      {packages.map((pkg) => (
        <a href={`/omra/${pkg.slug}`} class="od-card group block bg-white rounded-2xl overflow-hidden" style="box-shadow:0 4px 20px -6px rgba(6,43,82,0.1); border:1px solid rgba(6,43,82,0.06);">

          <div class="relative overflow-hidden" style="height:180px;">
            <img src={pkg.img} alt={pkg.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(3,20,42,0.5) 0%, transparent 60%);"></div>
            <div class="absolute top-3 left-3">
              <span class="inline-block px-2.5 py-1 rounded-lg text-[9px] font-bold tracking-widest uppercase text-white" style={`background:${pkg.badgeColor};`}>
                {pkg.badge}
              </span>
            </div>
          </div>

          <div class="p-5">
            <h3 class="font-heading font-bold text-lg mb-0.5" style="color:var(--ink);">
              {pkg.title} <span class="text-sm font-normal" style="color:var(--gold-deep);">— {pkg.subtitle}</span>
            </h3>

            <p class="flex items-center gap-1.5 text-gray-400 text-xs mt-1.5 mb-4">
              <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              {pkg.route} · départ Bruxelles/Paris
            </p>

            <div class="flex flex-wrap gap-3 mb-5">
              <span class="flex items-center gap-1 text-[11px] text-gray-500">
                <svg class="w-3.5 h-3.5" style="color:var(--gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
                Vols inclus
              </span>
              <span class="flex items-center gap-1 text-[11px] text-gray-500">
                <svg class="w-3.5 h-3.5" style="color:var(--gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                10 jours
              </span>
              <span class="flex items-center gap-1 text-[11px] text-gray-500">
                <svg class="w-3.5 h-3.5" style="color:var(--gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
                Hôtels au choix
              </span>
            </div>

            <div class="h-px bg-gray-100 mb-4"></div>

            <div class="flex items-end justify-between">
              <div>
                <p class="text-[9px] uppercase tracking-wider text-gray-400 mb-0.5">À partir de</p>
                <p class="font-heading font-bold" style="font-size:1.6rem; color:var(--ink); line-height:1;">
                  {pkg.price}€
                  <span class="text-xs font-normal text-gray-400">/pers.</span>
                </p>
              </div>
              <span class="od-btn inline-flex items-center justify-center font-bold text-xs tracking-wider rounded-full px-5 py-2.5 text-white transition-all duration-300" style="background:var(--navy-950);">
                Réserver
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .od-card {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .od-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px -12px rgba(6, 43, 82, 0.18);
  }
  .od-card:hover .od-btn {
    background: var(--gold) !important;
  }
</style>
