---
const packages = [
  {
    badge: "PROCHAIN DÉPART",
    badgeColor: "#C89A3D",
    title: "Omra 10 jours",
    subtitle: "24 Sept. — 3 Oct. 2026",
    route: "Madinah · Makkah · départ Bruxelles/Paris",
    duration: "10 jours",
    hotel: "Bosphorus & Voco",
    img: "/images/srv-hotel.jpg",
    prices: [
      { type: "Quadruple", price: "1 350" },
      { type: "Triple", price: "1 550" },
      { type: "Double", price: "1 750" },
    ],
  },
  {
    badge: "BEST-SELLER",
    badgeColor: "#B8323B",
    title: "Omra 10 jours",
    subtitle: "6 Nov. — 15 Nov. 2026",
    route: "Madinah · Makkah · départ Bruxelles/Paris",
    duration: "10 jours",
    hotel: "Bosphorus & Voco",
    img: "/images/kaaba-night.jpg",
    prices: [
      { type: "Quadruple", price: "1 350" },
      { type: "Triple", price: "1 550" },
      { type: "Double", price: "1 750" },
    ],
  },
];
---

<section class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex items-end justify-between mb-12">
      <div class="reveal">
        <span class="eyebrow mb-4">Omra 2026 · 1448</span>
        <h2 class="font-heading font-bold" style="font-size: clamp(1.9rem, 3.4vw, 2.7rem); color: var(--ink);">
          Nos prochains départs
        </h2>
        <p class="text-gray-500 mt-3 max-w-lg text-[15px] leading-relaxed">
          Forfait tout inclus : vols, visa, hôtels, transports et petits déjeuners.
        </p>
      </div>
      <div class="hidden sm:flex gap-2">
        <button id="od-prev" class="od-arrow flex items-center justify-center rounded-full border border-gray-200 transition-all duration-300" style="width:48px;height:48px;" aria-label="Précédent">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="od-next" class="od-arrow flex items-center justify-center rounded-full border border-gray-200 transition-all duration-300" style="width:48px;height:48px;" aria-label="Suivant">
          <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <div id="od-track" class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory" style="scrollbar-width:none; -webkit-overflow-scrolling:touch;">

      {packages.map((pkg) => (
        <div class="od-card flex-shrink-0 snap-start bg-white rounded-[20px] overflow-hidden" style="width:340px; box-shadow:0 8px 30px -10px rgba(6,43,82,0.12); border:1px solid rgba(6,43,82,0.06);">

          <div class="relative overflow-hidden" style="height:220px;">
            <img src={pkg.img} alt={pkg.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-700" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(3,20,42,0.4) 0%, transparent 50%);"></div>
            <div class="absolute top-4 left-4">
              <span class="inline-block px-3 py-1.5 rounded-lg text-[10px] font-bold tracking-widest uppercase text-white" style={`background:${pkg.badgeColor};`}>
                {pkg.badge}
              </span>
            </div>
          </div>

          <div class="p-6">
            <h3 class="font-heading font-bold text-xl mb-1" style="color:var(--ink);">
              {pkg.title} <span class="font-normal text-base" style="color:var(--gold-deep);">— {pkg.subtitle}</span>
            </h3>

            <p class="flex items-center gap-1.5 text-gray-400 text-[13px] mt-2 mb-5">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              {pkg.route}
            </p>

            <div class="flex flex-wrap gap-x-4 gap-y-2 mb-6">
              <span class="flex items-center gap-1.5 text-[13px] text-gray-500">
                <svg class="w-4 h-4" style="color:var(--gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
                Vols inclus
              </span>
              <span class="flex items-center gap-1.5 text-[13px] text-gray-500">
                <svg class="w-4 h-4" style="color:var(--gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                {pkg.duration}
              </span>
              <span class="flex items-center gap-1.5 text-[13px] text-gray-500">
                <svg class="w-4 h-4" style="color:var(--gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
                {pkg.hotel}
              </span>
            </div>

            <div class="h-px bg-gray-100 mb-5"></div>

            <div class="space-y-2.5 mb-6">
              {pkg.prices.map(p => (
                <div class="flex items-center justify-between">
                  <span class="text-[13px] text-gray-400">{p.type}</span>
                  <span class="font-heading font-bold text-[15px]" style="color:var(--ink);">{p.price}€ <span class="font-normal text-[11px] text-gray-400">/pers.</span></span>
                </div>
              ))}
            </div>

            <div class="flex items-end justify-between">
              <div>
                <p class="text-[10px] uppercase tracking-wider text-gray-400 mb-0.5">À partir de</p>
                <p class="font-heading font-bold" style="font-size:2rem; color:var(--ink); line-height:1;">
                  {pkg.prices[0].price}€
                  <span class="text-sm font-normal text-gray-400">/pers.</span>
                </p>
              </div>
              <a
                href={`https://wa.me/32497570058?text=${encodeURIComponent(`As salamo 3alaykoum wa rahmatullahi wa barakaatouh,\n\nJe suis intéressé(e) par votre Omra du ${pkg.subtitle}. Pourriez-vous me contacter pour en discuter ?\n\nMerci bien`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="od-btn inline-flex items-center justify-center font-bold text-sm tracking-wider rounded-full px-7 py-3 text-white transition-all duration-300"
                style="background:var(--navy-950);"
              >
                Réserver
              </a>
            </div>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  #od-track::-webkit-scrollbar {
    display: none;
  }

  .od-card {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .od-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px -15px rgba(6, 43, 82, 0.2);
  }
  .od-card:hover img {
    transform: scale(1.05);
  }

  .od-arrow:hover {
    border-color: var(--gold);
    background: var(--gold);
  }
  .od-arrow:hover svg {
    color: white;
  }

  .od-btn:hover {
    background: var(--gold) !important;
    transform: scale(1.04);
  }

  @media (max-width: 639px) {
    .od-card {
      width: 300px !important;
    }
  }
</style>

<script>
  function initOmraDates() {
    const track = document.getElementById('od-track');
    const prev = document.getElementById('od-prev');
    const next = document.getElementById('od-next');
    if (!track || track.dataset.init === '1') return;
    track.dataset.init = '1';

    const scrollAmount = 360;

    prev?.addEventListener('click', () => {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    next?.addEventListener('click', () => {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }

  document.addEventListener('astro:page-load', initOmraDates);
</script>
