---
const departures = [
  {
    id: 1,
    label: "Départ 1",
    dates: "24 Septembre — 3 Octobre 2026",
    duration: "10 jours",
    badge: "PROCHAIN DÉPART",
    badgeColor: "#C89A3D",
  },
  {
    id: 2,
    label: "Départ 2",
    dates: "6 Novembre — 15 Novembre 2026",
    duration: "10 jours",
    badge: "BEST-SELLER",
    badgeColor: "#B8323B",
  },
];

const hotels = [
  { name: "Bosphorus", img: "/images/srv-hotel.jpg" },
  { name: "Voco", img: "/images/kaaba-night.jpg" },
];

const pricing = [
  { type: "Quadruple", icon: "👥👥", persons: "4 pers./chambre", price: "1 350" },
  { type: "Triple", icon: "👥+", persons: "3 pers./chambre", price: "1 550" },
  { type: "Double", icon: "👥", persons: "2 pers./chambre", price: "1 750" },
];

const inclus = [
  { label: "Vols A/R", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>` },
  { label: "Visa", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z"/></svg>` },
  { label: "Hôtels", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z"/></svg>` },
  { label: "Transports", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H18.375m-7.5 0h7.5m-7.5 0l-1 3m8.5-3h2.25A2.25 2.25 0 0021 12.75V10.5A2.25 2.25 0 0018.75 8.25H6a2.25 2.25 0 00-2.25 2.25v2.25c0 1.243 1.007 2.25 2.25 2.25z"/></svg>` },
  { label: "Petits déj.", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265zm-3 0a.375.375 0 11-.53 0L9 2.845l.265.265zm6 0a.375.375 0 11-.53 0L15 2.845l.265.265z"/></svg>` },
];
---

<section class="py-24 lg:py-32 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- En-tête -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="eyebrow mb-5">Omra 2026 — 1448</span>
      <h2 class="font-heading font-bold mb-4" style="font-size: clamp(1.9rem, 3.4vw, 2.7rem); color: var(--ink);">
        Nos Omra à dates fixes
      </h2>
      <p class="text-gray-500 text-lg leading-relaxed">
        Forfait tout inclus au départ de Bruxelles ou Paris.<br>
        Vols, visa, hôtels, transports et petits déjeuners compris.
      </p>
    </div>

    <!-- Inclus -->
    <div class="flex flex-wrap justify-center gap-6 sm:gap-10 mb-14 reveal">
      {inclus.map(item => (
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-full flex items-center justify-center" style="background: rgba(200,154,61,0.1); color: var(--gold-deep);">
            <Fragment set:html={item.icon} />
          </div>
          <span class="text-xs font-semibold tracking-wide uppercase" style="color: var(--ink);">{item.label}</span>
        </div>
      ))}
    </div>

    <!-- Dates de départ -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-14 reveal">
      {departures.map(dep => (
        <div class="od-date-card relative overflow-hidden rounded-2xl p-6 sm:p-8" style="background: var(--navy-950);">
          <div class="absolute top-4 right-4">
            <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-white" style={`background: ${dep.badgeColor};`}>
              {dep.badge}
            </span>
          </div>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: rgba(200,154,61,0.15);">
              <svg viewBox="0 0 24 24" fill="none" stroke="#C89A3D" stroke-width="1.5" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
              </svg>
            </div>
            <div>
              <p class="text-white/50 text-xs font-semibold uppercase tracking-wider">{dep.label}</p>
              <p class="text-white font-heading font-bold text-lg">{dep.dates}</p>
            </div>
          </div>
          <div class="flex items-center gap-2 text-white/60 text-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {dep.duration} · Madinah · Makkah
          </div>
        </div>
      ))}
    </div>

    <!-- Hôtels -->
    <div class="mb-14 reveal">
      <h3 class="font-heading font-bold text-center mb-8" style="font-size: 1.3rem; color: var(--ink);">Nos hôtels</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {hotels.map(hotel => (
          <div class="od-hotel-card group relative overflow-hidden rounded-2xl" style="aspect-ratio: 16/10;">
            <img src={hotel.img} alt={hotel.name} loading="lazy" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(3,20,42,0.8) 0%, rgba(3,20,42,0.1) 60%, transparent);"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <p class="text-white font-heading font-bold text-xl">{hotel.name}</p>
              <p class="text-white/60 text-sm">Makkah</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Tarifs -->
    <div class="reveal">
      <h3 class="font-heading font-bold text-center mb-8" style="font-size: 1.3rem; color: var(--ink);">Tarifs par personne</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {pricing.map((p, i) => (
          <div class={`od-price-card relative overflow-hidden rounded-2xl p-7 text-center ${i === 2 ? 'od-price-featured' : ''}`}
               style={i === 2 ? 'background: var(--navy-950); color: white;' : 'background: white; border: 1px solid #e5e7eb;'}>
            {i === 2 && (
              <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(to right, var(--gold-light), var(--gold));"></div>
            )}
            <p class="text-sm font-semibold uppercase tracking-wider mb-1" style={i === 2 ? 'color: rgba(255,255,255,0.5);' : 'color: #9ca3af;'}>
              {p.type}
            </p>
            <p class="text-xs mb-5" style={i === 2 ? 'color: rgba(255,255,255,0.4);' : 'color: #9ca3af;'}>
              {p.persons}
            </p>
            <div class="mb-5">
              <span class="font-heading font-bold" style={`font-size: 2.5rem; ${i === 2 ? 'color: var(--gold);' : 'color: var(--ink);'}`}>
                {p.price}€
              </span>
              <span class="text-sm ml-1" style={i === 2 ? 'color: rgba(255,255,255,0.5);' : 'color: #9ca3af;'}>
                /pers.
              </span>
            </div>
            <a
              href={`https://wa.me/32497570058?text=${encodeURIComponent(`As salamo 3alaykoum wa rahmatullahi wa barakaatouh,\n\nJe suis intéressé(e) par votre Omra à dates fixes (chambre ${p.type.toLowerCase()} à ${p.price}€/pers). Pourriez-vous me contacter pour en discuter ?\n\nMerci bien`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 font-bold text-sm tracking-wider uppercase rounded-full px-8 py-3.5 transition-all duration-300"
              style={i === 2
                ? 'background: var(--gold); color: var(--navy-950);'
                : 'background: var(--navy-950); color: white;'}
            >
              Réserver
            </a>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .od-date-card {
    transition: transform 0.4s var(--ease-expo), box-shadow 0.4s var(--ease-expo);
  }
  .od-date-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 50px -15px rgba(3, 20, 42, 0.4);
  }

  .od-price-card {
    transition: transform 0.4s var(--ease-expo), box-shadow 0.4s var(--ease-expo);
  }
  .od-price-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px -15px rgba(3, 20, 42, 0.18);
  }
  .od-price-featured:hover {
    box-shadow: 0 20px 50px -15px rgba(3, 20, 42, 0.5);
  }
</style>
